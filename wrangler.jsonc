{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "exact-match-magic-08",
  "compatibility_date": "2026-06-01",
  "observability": {
    "enabled": true
  },
  "main": "src/server.ts",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
